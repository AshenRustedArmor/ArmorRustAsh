{
	"Name" : "AshenRustedArmor.ArmoryBalance",
	"Description" : "Rebalance mod.",
	"Version": "0.1.1",

	"LoadPriority": 1,
	"RequiredOnClient": true,

	"Localisation": [
		"resource/aa-balance_%language%.txt"
	],

	"Dependencies": {
		"ARMORY_UTILS" : "AshenRustedArmor.ArmoryUtils"
	},

	"Scripts": [
		{
			"Path": "weapons/_scorch.nut",
			"RunOn": "( CLIENT || SERVER ) && MP"
		}, {
			"Path": "weapons/_thermite.nut",
			"RunOn": "( CLIENT || SERVER ) && MP"
		}, {
			"Path": "weapons/_wave.nut",
			"RunOn": "( CLIENT || SERVER ) && MP"
		}, {
            "Path": "_equipment.nut",
            "RunOn": "SERVER || CLIENT || UI",
            "Init": "AshenArmoryBalance_Equipment_Init"
        }
	]
}